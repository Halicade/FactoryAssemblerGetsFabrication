<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>VFEFactory_AutomatedApriary</defName>
		<label>automated apriary</label>
		<description>An automated apriary for autonomously mass producing honey on a large scale with no human input.\n\nFactory buildings need factory hoppers for input and output. They produce significant heat and consume much power, but can be overclocked for higher efficiency, increasing both heat generation and power consumption. Needs to be constructed on factory floor.</description>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/Factories/AutomatedApiary/AutomatedApiary</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(5,5)</drawSize>
			<damageData>
				<cornerTL>Damage/Corner</cornerTL>
				<cornerTR>Damage/Corner</cornerTR>
				<cornerBL>Damage/Corner</cornerBL>
				<cornerBR>Damage/Corner</cornerBR>
			</damageData>
		</graphicData>
		<thingCategories>
			<li>VFEFactory_FactoryCategory</li>
		</thingCategories>
		<costList>
			<Steel>270</Steel>
			<ComponentIndustrial>6</ComponentIndustrial>
		</costList>
		<constructionSkillPrerequisite>6</constructionSkillPrerequisite>
		<altitudeLayer>Building</altitudeLayer>
		<rotatable>true</rotatable>
		<neverMultiSelect>true</neverMultiSelect>
		<terrainAffordanceNeeded>FactoryFloor</terrainAffordanceNeeded>
		<uiIconScale>0.8</uiIconScale>
		<fillPercent>0.5</fillPercent>
		<useHitPoints>True</useHitPoints>
		<statBases>
			<Mass>65</Mass>
			<Beauty>-10</Beauty>
			<WorkToBuild>5000</WorkToBuild>
			<MaxHitPoints>550</MaxHitPoints>
			<Flammability>1</Flammability>
			<VEF_BuildingMaxOverclockFactor>1</VEF_BuildingMaxOverclockFactor>
			<VEF_BuildingBreakdownFactor>2</VEF_BuildingBreakdownFactor>
		</statBases>
		<tickerType>Rare</tickerType>
		<size>(3,3)</size>
		<designationCategory>VFEFactory_Factories</designationCategory>
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<hasInteractionCell>True</hasInteractionCell>
		<interactionCellOffset>(0,0,-2)</interactionCellOffset>
		<surfaceType>Item</surfaceType>
		<researchPrerequisites>
			<li>VFE_ComplexFactories</li>
			<li>VFEM2_Beekeeping</li>
		</researchPrerequisites>
		<building>
			<relatedBuildCommands>
				<li>VFEFactory_FactoryHopper</li>
			</relatedBuildCommands>
			<buildingTags>
				<li>Production</li>
			</buildingTags>
			<workTableRoomRole>VFEFactory_FactoryRoom</workTableRoomRole>
			<workTableNotInRoomRoleFactor>0.5</workTableNotInRoomRoleFactor>
		</building>
		<inspectorTabs>
			<li>PipeSystem.ITab_Processor</li>
		</inspectorTabs>
		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>1000</basePowerConsumption>
			</li>
			<li>
				<compClass>PipeSystem.CompPowerTrader_Overclocked</compClass>
			</li>
			<li Class="CompProperties_HeatPusher">
				<compClass>PipeSystem.CompHeatPusherPowered_Overclocked</compClass>
				<heatPerSecond>9</heatPerSecond>
				<heatPushMaxTemperature>66</heatPushMaxTemperature>
			</li>
			<li Class="CompProperties_Flickable"/>
			<li Class="PipeSystem.CompProperties_AdvancedResourceProcessor">
				<notWorkingKey>VFEFactory_FactoryNotWorking</notWorkingKey>
				<canOverclock>true</canOverclock>
				<overclockGizmo>UI/Gizmo/Factory_Overclock</overclockGizmo>
				<overclockLabel>VFEFactory_Overclock</overclockLabel>
				<overclockWindowLabel>VFEFactory_OverclockWindowLabel</overclockWindowLabel>
				<overclockDesc>VFEFactory_OverclockDesc</overclockDesc>
				<alwaysShowProgressBar>true</alwaysShowProgressBar>
				<processes>
					<li>VFEFactory_Idkhoneylol</li>
				</processes>
				<hideSettings>true</hideSettings>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>VFEFactory_Booster</li>
					<li>VFEFactory_Heatsink</li>
				</linkableFacilities>
			</li>
		</comps>
		<minifiedDef>MinifiedThing</minifiedDef>
	</ThingDef>
	
</Defs>
