<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!--
    How to set up recipe.
    Get original recipes filter category and count. 
    Multiply count by 20. That is countNeeded which goes in ingredients
    
    MassProductionExpansion.ModExtension.nutritionChanger
    nutritionToMake is count times 2
    -->
    <PipeSystem.ProcessDef Name="MPE_GenericMealBase" Abstract="true">
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <autoGrabFromHoppers>true</autoGrabFromHoppers>
        <useIngredients>true</useIngredients>
        <autoInputSlots>
            <li>(0,0,3)</li>
            <li>(1,0,3)</li>
            <li>(-1,0,3)</li>
        </autoInputSlots>
        <isFactoryProcess>true</isFactoryProcess>
        <autoExtract>true</autoExtract>
        <onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
        <sustainerWhenWorking>true</sustainerWhenWorking>
        <sustainerDef>VFEFactory_AutomatedCookingSustainer</sustainerDef>
        <effecterWhenWorking>true</effecterWhenWorking>
        <effecterDef>VFEFactory_Cook</effecterDef>
        <maxOutputCount>20</maxOutputCount>

    </PipeSystem.ProcessDef>

    <PipeSystem.ProcessDef ParentName="MPE_GenericMealBase">
        <defName>MPE_T2_MakeSurvivalMeal</defName>
        <label>Make survival meal</label>
        <labelOverride>new Make survival meal</labelOverride>
        <description>Prepare packaged survival meals from a combination of meat and plant ingredients. Much of the ingredients are wasted in the preservation process. A total of 2.4 nutrition will make 4 survival meals.</description>
        <priorityInBillList>2</priorityInBillList>
        <ticks>7200</ticks>
        <ingredients>
            <li>
                <thingCategory>FoodRaw</thingCategory>
                <countNeeded>48</countNeeded>
            </li><!--
            <li>
                <thingCategory>MeatRaw</thingCategory>
                <countNeeded>24</countNeeded>
            </li>
            <li>
                <thingCategory>PlantFoodRaw</thingCategory>
                <countNeeded>24</countNeeded>
            </li>-->
        </ingredients>
        <results>
            <li>
                <thing>MealSurvivalPack</thing>
                <count>4</count>
                <workerClass>MassProductionExpansion.ResultWorker.Meals</workerClass>
                <outputStringOverride>VFEFactory_SurvivalMealOutput</outputStringOverride>
            </li>
        </results>
        <researchPrerequisites>
            <li>PackagedSurvivalMeal</li>
            <li>VFE_BasicFactories</li>
        </researchPrerequisites>
        <modExtensions>
            <li Class="MassProductionExpansion.ModExtension.nutritionChanger">
                <nutritionToMake>2.4</nutritionToMake>
            </li>
        </modExtensions>
    </PipeSystem.ProcessDef>
    
    <PipeSystem.ProcessDef>
        <defName>MPE_T2_MakeSimpleMeal</defName>
        <label>Make simple meal</label>
        <labelOverride>Make simple meal</labelOverride>
        <description>Prepare packaged survival meals from a combination of meat and plant ingredients. Much of the ingredients are wasted in the preservation process. A total of 2.4 nutrition will make 4 survival meals.</description>
        <priorityInBillList>2</priorityInBillList>
        <spawnOnInteractionCell>true</spawnOnInteractionCell>
        <autoGrabFromHoppers>true</autoGrabFromHoppers>
        <useIngredients>true</useIngredients>
        <autoInputSlots>
            <li>(0,0,3)</li>
            <li>(1,0,3)</li>
            <li>(-1,0,3)</li>
        </autoInputSlots>
        <ticks>7200</ticks>
        <ingredients>
            <li>
                <thingCategory>MeatRaw</thingCategory>
                <countNeeded>24</countNeeded>
            </li>
            <li>
                <thingCategory>PlantFoodRaw</thingCategory>
                <countNeeded>24</countNeeded>
            </li>
        </ingredients>
        <results>
            <li>
                <thing>MealSimple</thing>
                <count>4</count>
                <workerClass>MassProductionExpansion.ResultWorker.Meals</workerClass>
                <outputStringOverride>VFEFactory_SurvivalMealOutput</outputStringOverride>
            </li>
        </results>
        <isFactoryProcess>true</isFactoryProcess>
        <autoExtract>true</autoExtract>
        <onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
        <researchPrerequisites>
            <li>PackagedSurvivalMeal</li>
            <li>VFE_BasicFactories</li>
        </researchPrerequisites>
        <sustainerWhenWorking>true</sustainerWhenWorking>
        <sustainerDef>VFEFactory_AutomatedCookingSustainer</sustainerDef>
        <effecterWhenWorking>true</effecterWhenWorking>
        <effecterDef>VFEFactory_Cook</effecterDef>
        <maxOutputCount>20</maxOutputCount>
        <modExtensions>
            <li Class="MassProductionExpansion.ModExtension.nutritionChanger">
                <nutritionToMake>2.4</nutritionToMake>
            </li>
        </modExtensions>
    </PipeSystem.ProcessDef>

    
</Defs>